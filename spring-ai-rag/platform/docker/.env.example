# 環境変数
# ローカル開発用の設定
# このファイルを .env にコピーして使用してください

# Redisパスワード
REDIS_HOST=localhost
REDIS_PASSWORD=123456

# データベース接続情報
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=youlai_boot
MYSQL_USERNAME=root
MYSQL_ROOT_PASSWORD=123456

# MinIO認証情報
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# デバイス監視デモモード
DEMO_MODE=true

# データディレクトリのベースパス
# ローカル環境に合わせて変更してください
BASEPATH=/mydata/ai-rag

# Docker platform (optional)
# - Use `./compose-env.sh up -d` to auto-detect (arm64 -> linux/arm64, x86_64 -> linux/amd64)
# - Or set explicitly in your shell before running compose:
#   EC_DEMO_PLATFORM=linux/arm64
#   EC_DEMO_PLATFORM=linux/amd64
